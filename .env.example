# Copy to .env and fill in real values. Never commit .env to version control.

SECRET_KEY=your-secret-key-here
DEBUG=False

# Comma-separated list of allowed hostnames, e.g. town-of-west-point.vercel.app,localhost
ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres connection string from Vercel Postgres / Neon / Supabase
# Leave blank to use SQLite locally
DATABASE_URL=postgres://user:password@host:5432/dbname

# Redis connection string from Upstash or similar
# Leave blank to use in-memory channel layer (single-process only)
REDIS_URL=redis://default:password@host:6379
